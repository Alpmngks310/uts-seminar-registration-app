<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- shadow soft / base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FDFEFF" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="#D9E7F5" />
        </shape>
    </item>

    <!-- inner soft background -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#F8FCFF"
                android:endColor="#FDFEFF"
                android:angle="270" />
            <corners android:radius="20dp" />
            <padding
                android:left="16dp"
                android:top="12dp"
                android:right="16dp"
                android:bottom="12dp" />
        </shape>
    </item>

</layer-list>