<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="-35dp"
        android:layout_marginTop="-35dp"
        android:background="@drawable/bg_circle_top" />

    <View
        android:layout_width="170dp"
        android:layout_height="170dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="-45dp"
        android:layout_marginBottom="-45dp"
        android:background="@drawable/bg_circle_bottom" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="24dp"
            android:paddingTop="36dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="120dp"
                android:layout_height="120dp"
                app:cardBackgroundColor="#EEF8F1"
                app:cardCornerRadius="60dp"
                app:cardElevation="6dp"
                app:strokeColor="#DDEEDF"
                app:strokeWidth="1dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="26dp"
                    android:src="@android:drawable/checkbox_on_background"
                    android:scaleType="fitCenter"
                    android:contentDescription="Success Icon" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvSuccessTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Registration Successful"
                android:textColor="#23313B"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Your seminar registration has been submitted successfully."
                android:textColor="#5F6B75"
                android:textSize="14sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="22dp"
                app:cardElevation="8dp"
                app:strokeColor="#E8EEF4"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Registration Details"
                        android:textColor="#23313B"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvNameResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Name: -"
                        android:textColor="#66737E"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvEmailResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Email: -"
                        android:textColor="#66737E"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvPhoneResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Phone: -"
                        android:textColor="#66737E"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvGenderResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Gender: -"
                        android:textColor="#66737E"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvSeminarResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Seminar: -"
                        android:textColor="#66737E"
                        android:textSize="14sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackHome"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="#DDF3E8"
                android:text="Back to Home"
                android:textAllCaps="false"
                android:textColor="#244233"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="28dp" />

        </LinearLayout>

    </ScrollView>

</FrameLayout>